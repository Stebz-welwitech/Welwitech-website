---
interface Props {
  title: string;
  items: {
    icon: string;
    title: string;
    description: string;
    cta: { title: string; url: string };
  }[];
}

const { title, items } = Astro.props;
---

<section class="sy-expertises" id="expertises">
  <div class="container">
    <h2 class="heading" data-sy-reveal="words">{title}</h2>

    <div class="grid">
      {
        items.map((item, i) => (
          <div class:list={["card", i === 0 && "card--wide"]}>
            <span class="num u-text">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="card-title u-heading" data-sy-reveal="words">{item.title}</h3>
            <p class="card-desc u-text" data-sy-reveal="lines">{item.description}</p>
            <a class="card-cta u-text" href={item.cta.url}>
              {item.cta.title}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sy-expertises {
    margin: 8rem 0;
    position: relative;
    z-index: 2;
  }

  .container {
    @extend %u-container;
  }

  .heading {
    @extend %u-heading;
    --fs: clamp(1.8rem, 4vw, 3rem);
    --fw: 300;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(var(--rgb-text), 0.06);
    border: 1px solid rgba(var(--rgb-text), 0.06);
    border-radius: 1rem;
    overflow: hidden;

    @media (--mq-tablet) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (--mq-phone) {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background: var(--color-white);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    transition: background 0.4s var(--ease-out-cubic);

    &:hover {
      background: var(--color-brand-3);
    }

    @media (--mq-phone) {
      padding: 1.5rem;
    }

    @media (--mq-phone-sm) {
      padding: 1.25rem;
    }
  }

  .card--wide {
    @media (min-width: 988px) {
      grid-column: span 3;
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto 1fr auto;
      column-gap: 2rem;

      .num { grid-column: 1; grid-row: 1; }
      .card-title { grid-column: 1 / -1; grid-row: 1; padding-left: 3rem; }
      .card-desc { grid-column: 1 / -1; grid-row: 2; max-width: 50em; }
      .card-cta { grid-column: 1 / -1; grid-row: 3; }
    }

    @media (--mq-tablet) {
      grid-column: span 2;
    }

    @media (--mq-phone) {
      grid-column: auto;
    }
  }

  .num {
    --fs: var(--font-size-xs);
    --fw: 400;
    color: rgb(var(--rgb-brand-1));
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .card-title {
    --fs: 1.15rem;
    --fw: 400;
    --lh: 1.25;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .card-cta {
    --fs: var(--font-size-sm);
    --fw: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: rgb(var(--rgb-brand-1));
    text-decoration: none;
    margin-top: auto;

    svg {
      transition: transform 0.4s var(--ease-out-expo);
    }

    &:hover svg {
      transform: translateX(4px);
    }
  }
</style>
