---
import Button from "./Button.astro";
import logoIcon from "../assets/logo-icon.png";
import type { Link } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  link1?: Link;
  link2?: Link;
}

const { logoUrl, logoAlt, link1, link2, links } = Astro.props;
---

<header>
  <sy-head>
    <nav class="bar" aria-label="Navigation principale">
      <a class="logo" href={logoUrl}>
        <img src={logoIcon.src} alt="" width="28" height="28" />
        <span class="logo-text">{logoAlt}</span>
      </a>

      <div class="menu">
        <ul>
          {
            links.map((l) => (
              <li>
                <a href={l.url}>{l.title}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="actions">
        <a href="#" class="lang-switch u-text" aria-label="Switch language">FR</a>

        <button type="button" class="theme-toggle" aria-label="Changer de thème">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        {link2 ? <Button {...link2} revealable={false} /> : null}

        <button type="button" class="toggle" aria-label="Menu">
          <span class="u-sr-only">Toggle Mobile Menu</span>
          <span aria-hidden>
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </nav>
  </sy-head>
</header>

<style>
  /*
   * HEADER STRUCTURE:
   * sy-head (fixed, full viewport width, padding = space around the bar)
   *   .bar (the visible pill — border-radius, background, content)
   */

  sy-head {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    pointer-events: none;
  }

  .bar {
    --bar-radius: 1rem;

    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.55rem 1.25rem;
    border-radius: var(--bar-radius);
    pointer-events: auto;

    /* default: transparent */
    background: transparent;
    transition:
      background 0.4s var(--ease-out-cubic),
      box-shadow 0.4s var(--ease-out-cubic),
      max-width 0.5s var(--ease-out-cubic),
      padding 0.4s var(--ease-out-cubic);

    /* on scroll: glass pill */
    :global(body.is-nav-small) & {
      max-width: 60rem;
      background: rgba(var(--rgb-white), 0.9);
      backdrop-filter: blur(24px) saturate(1.3);
      -webkit-backdrop-filter: blur(24px) saturate(1.3);
      box-shadow: 0 1px 8px rgba(var(--rgb-text), 0.04);
    }

    :global([data-theme="dark"] body.is-nav-small) & {
      background: rgba(var(--rgb-brand-3), 0.9);
    }

    @media (--mq-tablet) {
      padding: 0.5rem 1rem;
    }
  }

  /* ---- Logo ---- */
  .logo {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;

    img {
      width: 1.5rem;
      height: 1.5rem;
      object-fit: contain;
    }

    .logo-text {
      font-family: var(--font-inter);
      font-weight: 500;
      font-size: 1rem;
      letter-spacing: 0.03em;
      color: currentcolor;
    }
  }

  /* ---- Nav menu ---- */
  .menu {
    display: flex;
    position: absolute;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: min-content;

    @media (--mq-tablet) {
      align-items: center;
      justify-content: center;
      width: 100vw;
      height: 100dvh;
      position: fixed;
      z-index: 2;
      background: var(--color-bg);
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      margin: 0;
      border-radius: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.5s var(--ease-out-expo);

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }
    }

    :global(ul) {
      @extend %u-text;

      --fs: var(--font-size-sm);
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      gap: 1.25em;

      @media (--mq-tablet) {
        flex-direction: column;
        font-size: 1.75rem;
        gap: 1rem;
        color: var(--color-text);
      }

      :global(a) {
        text-decoration: none;
        position: relative;

        &::before {
          content: "";
          position: absolute;
          height: 1px;
          background: currentcolor;
          top: 115%;
          width: 100%;
          left: 0;
          pointer-events: none;
          transform: scaleX(0);
          transition: transform 0.3s var(--ease-out-expo);
          transform-origin: right;
        }

        &:hover,
        &:focus {
          &::before {
            transform: scaleX(1);
            transform-origin: left;
          }
        }
      }
    }
  }

  /* ---- Right actions ---- */
  .actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    z-index: 3;

    :global(.btn) {
      @media (--mq-tablet) {
        display: none;
      }
    }
  }

  .lang-switch {
    --fs: var(--font-size-xs);
    --fw: 500;
    text-decoration: none;
    color: var(--color-text);
    opacity: 0.45;
    letter-spacing: 0.04em;
    transition: opacity 0.25s var(--ease-out-cubic);

    &:hover { opacity: 1; }
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text);
    opacity: 0.45;
    transition: opacity 0.25s var(--ease-out-cubic);

    &:hover { opacity: 1; }

    .icon-moon { display: none; }

    :global([data-theme="dark"]) & {
      .icon-sun { display: none; }
      .icon-moon { display: block; }
    }
  }

  /* ---- Hamburger ---- */
  .toggle {
    border: none;
    background: none;
    padding: 0.5rem;
    cursor: pointer;
    align-items: center;
    display: none;
    z-index: 3;
    color: var(--color-text);
    opacity: 0.5;
    min-width: 2.75rem;
    min-height: 2.75rem;
    justify-content: center;

    &:hover { opacity: 1; }

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 0.85rem;
      width: 1.25rem;

      span {
        display: flex;
        width: 100%;
        height: 1.5px;
        background: currentcolor;
        border-radius: 1px;
        transition: transform 0.25s var(--ease-out-cubic);

        &:nth-child(2) {
          transition-property: opacity;
        }
      }
    }

    :global(body.is-nav-opened) & {
      > span span {
        &:first-child {
          transform: translateY(calc(0.425rem - 0.75px)) rotate(45deg);
        }

        &:nth-child(2) {
          opacity: 0;
        }

        &:last-child {
          transform: translateY(calc(-0.425rem + 0.75px)) rotate(-45deg);
        }
      }
    }
  }
</style>

<script>
  import { addScrollObserver } from "../utils/observers";

  const heroSelectors = ["sy-hero-home"];

  class Header extends HTMLElement {
    smallThreshold = 100;
    toggleEl = this.querySelector(".toggle")!;
    hero = document.querySelector(heroSelectors.join(","));
    prevY = -1;

    constructor() {
      super();

      addScrollObserver(this);

      this.toggleEl.addEventListener("click", this.toggleNav);

      this.onResize();
      this.onScroll(window.scrollY);
    }

    onScroll(y: number) {
      this.prevY = y;

      const classList = document.body.classList;

      const shouldBeSmall = y > this.smallThreshold;
      const isSmall = classList.contains("is-nav-small");

      if (shouldBeSmall !== isSmall) {
        classList.toggle("is-nav-small", shouldBeSmall);
      }

      if (classList.contains("is-nav-hidden")) {
        classList.remove("is-nav-hidden");
      }
    }

    toggleNav = () => {
      document.body.classList.toggle("is-nav-opened");
    };

    onResize() {
      const hero = this.hero;
      const bcr = this.getBoundingClientRect();
      const heroBcr = hero && hero.getBoundingClientRect();

      this.smallThreshold = heroBcr ? heroBcr.height - bcr.height : bcr.height;
    }
  }

  customElements.define("sy-head", Header);

  // ---- Language switcher ----
  const langLink = document.querySelector<HTMLAnchorElement>('.lang-switch');
  if (langLink) {
    const isEn = window.location.pathname.startsWith('/en');
    langLink.textContent = isEn ? 'FR' : 'EN';
    langLink.href = isEn ? '/' : '/en/';
  }

  // ---- Dark mode toggle ----
  const themeBtn = document.querySelector('.theme-toggle');

  function getPreferredTheme(): string {
    const stored = localStorage.getItem('theme');
    if (stored) return stored;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  applyTheme(getPreferredTheme());

  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });
</script>
