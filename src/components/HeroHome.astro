---
import type { Link } from "../types";
import Button from "./Button.astro";

interface Props {
  title: string;
  subtitle?: string;
  cta?: Link;
  stats?: { value: string; label: string }[];
}

const { title, subtitle, cta, stats } = Astro.props;
---

<div class="sy-hero-home">
  <div class="bg"></div>
  <div class="u-container container">
    <div class="inner">
      <div class="content">
        <h1 class="u-heading title" data-sy-reveal="words">{title}</h1>
        {
          subtitle ? (
            <p class="u-text subtitle" data-sy-reveal="lines">
              {subtitle}
            </p>
          ) : null
        }
        {cta ? <Button {...cta} arrow class="cta" /> : null}

        {stats && stats.length > 0 && (
          <div class="stats">
            {stats.map((s) => (
              <div class="stat" data-sy-reveal="words">
                <span class="stat-value u-heading" data-count-to={s.value}>{s.value}</span>
                <span class="stat-label u-text">{s.label}</span>
              </div>
            ))}
          </div>
        )}
      </div>
      <div data-gl-place></div>
    </div>
  </div>
</div>

<style>
  .sy-hero-home {
    position: relative;
    overflow: hidden;
  }

  .bg {
    &:before,
    &:after {
      content: "";
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
    }

    &:before {
      background: linear-gradient(
        160deg,
        var(--color-bg) 0%,
        rgba(var(--rgb-brand-1), 0.06) 30%,
        rgba(var(--rgb-brand-5), 0.04) 60%,
        var(--color-bg) 100%
      );
      background-position: center;
      mask: linear-gradient(0deg, rgba(0, 0, 0, 0) 1%, rgba(0, 0, 0, 1) 100%);
    }

    &:after {
      backdrop-filter: blur(5px);
    }
  }

  .inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 11rem 0 8rem;
    position: relative;
    z-index: 1;
    min-height: 100vh;

    @media (--mq-tablet) {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .title {
    --fs: clamp(3rem, 5vw, 5rem);
    --lh: 0.97;
    --ls: -0.025em;
    --fw: 300;
    max-width: 7em;
  }

  .subtitle {
    --fs: var(--font-size-md);
    max-width: 28em;
    margin-top: 1.75rem;
    color: var(--color-text-alt);
    line-height: 1.65;
  }

  .cta {
    margin-top: 2.5rem;
  }

  .stats {
    display: flex;
    gap: 3rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--rgb-text), 0.06);

    @media (--mq-phone) {
      gap: 1.5rem;
      margin-top: 2.5rem;
    }

    @media (--mq-phone-sm) {
      gap: 1rem;
    }
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    --fs: 1.75rem;
    --fw: 300;
    --lh: 1;
    color: var(--color-text);
  }

  .stat-label {
    --fs: var(--font-size-xs);
    color: var(--color-text-alt);
    letter-spacing: 0.02em;
  }

  [data-gl-place] {
    --d: 1;
    --s: 22rem;
    margin-top: -12rem;

    @media (--mq-desktop-lg) {
      --s: 20rem;
    }

    @media (--mq-tablet) {
      margin: 0;
      position: absolute;
      top: 100%;
      left: 0;
      margin: 0 auto;
      right: 0;
      width: 14rem;
      transform: translateY(-60%);
    }

    @media (--mq-tablet-sm) {
      --s: 20rem;
    }
  }
</style>

<script>
  function animateCounters() {
    const els = document.querySelectorAll<HTMLElement>('[data-count-to]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        observer.unobserve(el);

        const raw = el.dataset.countTo || '';
        const match = raw.match(/^(\d+)/);
        if (!match) return;

        const target = parseInt(match[1], 10);
        const suffix = raw.replace(match[1], '');
        const duration = 1200;
        const start = performance.now();

        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(target * eased);

          el.textContent = current + suffix;

          if (progress < 1) requestAnimationFrame(tick);
        }

        el.textContent = '0' + suffix;
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.5 });

    els.forEach((el) => observer.observe(el));
  }

  animateCounters();
</script>
