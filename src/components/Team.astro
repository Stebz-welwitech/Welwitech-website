---
interface Props {
  title: string;
  subtitle: string;
  members: {
    initials: string;
    name: string;
    role: string;
    bio: string;
  }[];
}

const { title, subtitle, members } = Astro.props;
---

<div class="sy-team" id="equipe">
  <div class="u-container">
    <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
    <p class="u-text subtitle" data-sy-reveal="lines">{subtitle}</p>

    <div class="members">
      {
        members.map((member) => (
          <div class="card">
            <div class="avatar">
              <span class="u-heading initials">{member.initials}</span>
            </div>
            <h3 class="u-heading name" data-sy-reveal="words">
              {member.name}
            </h3>
            <p class="u-text role" data-sy-reveal="words">{member.role}</p>
            <p class="u-text bio" data-sy-reveal="lines">{member.bio}</p>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .sy-team {
    margin: 8rem 0;
    position: relative;
    z-index: 2;
  }

  .title {
    --fs: clamp(1.8rem, 4vw, 3rem);
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 0.1em;
  }

  .subtitle {
    --fs: var(--font-size-md);
    color: var(--color-text-alt);
    max-width: 32em;
    text-align: center;
    margin: 0 auto 3rem;
  }

  .members {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      max-width: 24rem;
      margin: 0 auto;
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
    border: 1px solid rgba(var(--rgb-text), 0.06);
    border-radius: 1rem;
    background: var(--color-white);
  }

  .avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: var(--color-brand-3);
    border: 1px solid rgba(var(--rgb-text), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .initials {
    --fs: 1.1rem;
    --fw: 400;
    color: rgb(var(--rgb-brand-1));
    line-height: 1;
    letter-spacing: 0.04em;
  }

  .name {
    --fs: 1.25rem;
    --fw: 500;
    margin: 0 0 0.2em;
  }

  .role {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    margin: 0 0 1.25rem;
  }

  .bio {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    line-height: 1.6;
    margin: 0;
  }
</style>
