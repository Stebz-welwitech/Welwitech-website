---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { useTranslations } from "../i18n/utils";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Studio digital spécialisé en Design, Mobile, Web, SaaS & Intelligence Artificielle. Équipe senior, tarifs transparents, livraison garantie. Dubai · France · International." } = Astro.props;
const ogImage = "/og-image.jpg";
const siteUrl = "https://welwitech.com";
const t = useTranslations();

const links = [
  { title: "Expertises", url: "#expertises" },
  { title: "Méthode", url: "#methode" },
  { title: "Tarifs", url: "#tarifs" },
  { title: "Blog", url: "/blog" },
  { title: "Contact", url: "#contact" },
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Welwitech" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Welwitech" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- JSON-LD Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Welwitech",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.png`,
      "description": description,
      "email": "contact@welwitech.com",
      "areaServed": ["FR", "AE", "International"],
      "address": [
        {
          "@type": "PostalAddress",
          "addressCountry": "AE",
          "addressLocality": "Dubai"
        },
        {
          "@type": "PostalAddress",
          "addressCountry": "FR"
        }
      ],
      "founder": [
        { "@type": "Person", "name": "Maurice Zayat", "jobTitle": "Commercial & BD" },
        { "@type": "Person", "name": "Stéphane Zayat", "jobTitle": "CTO / Tech Lead" },
        { "@type": "Person", "name": "Jess Biclair", "jobTitle": "Développeur & IA" }
      ],
      "knowsAbout": ["UX/UI Design", "Mobile Development", "Web Development", "SaaS", "Artificial Intelligence", "AI Agents"],
      "priceRange": "€€"
    })} />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <Font cssVariable="--font-roboto-slab" preload />
    <Font cssVariable="--font-inter" preload />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main" class="skip-link">{t("accessibility.skip-to-content")}</a>
    <Header
      logoUrl="/"
      logoAlt="Welwitech"
      links={links}
      link2={{ title: "Devis gratuit", url: "https://cal.com/maurice-zayat-2uyfey/20min", target: "_blank" }}
    />
    <main id="main">
      <slot />
    </main>
    <Footer logoUrl="/" logoAlt="Welwitech" links={links} />

    <!-- Sticky mobile CTA -->
    <div class="sticky-cta">
      <a href="https://cal.com/maurice-zayat-2uyfey/20min" target="_blank" rel="noopener" class="u-text sticky-cta-btn">
        Devis gratuit
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <CookieBanner />

    <!-- Back to top -->
    <button class="back-to-top" aria-label="Retour en haut" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
    </button>

    <SmoothScroll />
  </body>
</html>

<style>
  /* ---- Scroll progress ---- */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: rgb(var(--rgb-brand-1));
    z-index: 100;
    transition: none;
    pointer-events: none;
  }

  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }

  /* ---- Sticky mobile CTA ---- */
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 1.25rem;
    bottom: calc(1.25rem + env(safe-area-inset-bottom, 0));
    left: 0;
    right: 0;
    z-index: 50;
    pointer-events: none;
    text-align: center;

    @media (--mq-tablet) {
      display: block;
    }
  }

  .sticky-cta-btn {
    --fs: var(--font-size-xs);
    --fw: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.85em 2em;
    border-radius: 100px;
    background: rgb(var(--rgb-brand-1));
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.02em;
    pointer-events: auto;
    box-shadow: 0 4px 20px rgba(var(--rgb-brand-1), 0.3);
    transition: box-shadow 0.3s var(--ease-out-cubic), transform 0.3s var(--ease-out-cubic);

    &:active {
      transform: scale(0.97);
    }
  }

  /* ---- Back to top ---- */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 40;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1px solid rgba(var(--rgb-text), 0.08);
    background: rgba(var(--rgb-white), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    :global([data-theme="dark"]) & {
      background: rgba(var(--rgb-brand-3), 0.85);
    }
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.5rem);
    transition: opacity 0.35s var(--ease-out-cubic), transform 0.35s var(--ease-out-cubic), border-color 0.25s var(--ease-out-cubic);

    &.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    &:hover {
      border-color: rgba(var(--rgb-brand-1), 0.25);
    }

    @media (--mq-tablet) {
      bottom: 5rem;
      right: 1rem;
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>

<script>
  import "../utils/reveals";

  // ---- Scroll progress bar ----
  const progressBar = document.querySelector<HTMLElement>('.scroll-progress');
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : '0%';
    }, { passive: true });
  }

  const btn = document.querySelector<HTMLButtonElement>('.back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('is-visible', window.scrollY > 600);
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
