---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page introuvable" description="La page que vous recherchez n'existe pas ou a été déplacée.">
  <section class="error">
    <div class="error__inner">
      <span class="error__code">404</span>
      <h1 class="error__title">Cette page n'existe pas</h1>
      <p class="error__text">La page que vous recherchez a peut-être été déplacée ou supprimée.</p>
      <a href="/" class="error__link">
        Retour à l'accueil
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .error {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .error__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .error__code {
    font-size: clamp(8rem, 20vw, 14rem);
    font-weight: 200;
    line-height: 1;
    color: rgba(var(--rgb-brand-1), 0.15);
    letter-spacing: -0.04em;
    user-select: none;
  }

  .error__title {
    @extend %u-heading;
    --fs: var(--font-size-md);
    margin-top: -0.5rem;
    color: var(--color-text);
  }

  .error__text {
    @extend %u-text;
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    max-width: 28ch;
    margin-top: 0.25rem;
  }

  .error__link {
    @extend %u-text;
    --fs: var(--font-size-xs);
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 1.5rem;
    color: rgb(var(--rgb-brand-1));
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap 0.3s ease;

    &:hover {
      gap: 0.75em;
    }
  }
</style>
