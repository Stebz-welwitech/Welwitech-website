---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string): string {
  const months = [
    "janvier", "février", "mars", "avril", "mai", "juin",
    "juillet", "août", "septembre", "octobre", "novembre", "décembre",
  ];
  const d = new Date(dateStr);
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
---

<Layout
  title={`${post.data.title} — Welwitech`}
  description={post.data.description}
  ogType="article"
  articleDate={post.data.date}
  articleAuthor={post.data.author}
  breadcrumbs={[
    { name: "Accueil", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: post.data.title, url: `/blog/${post.id}` },
  ]}
>
  <article class="blog-post">
    <div class="blog-post__back">
      <a href="/blog" class="blog-post__back-link u-text">← Blog</a>
    </div>

    <header class="blog-post__header">
      <span class="blog-post__date u-text">{formatDate(post.data.date)}</span>
      <h1 class="blog-post__title u-heading">{post.data.title}</h1>
      <span class="blog-post__author u-text">Par {post.data.author}</span>
    </header>

    <div class="blog-post__content prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    @extend %u-container;
    padding-top: 10rem;
    padding-bottom: 6rem;
  }

  .blog-post__back {
    margin-bottom: 3rem;
  }

  .blog-post__back-link {
    @extend %u-text;
    --fs: var(--font-size-sm);
    --fw: 400;
    color: var(--color-text-alt);
    text-decoration: none;
    transition: color 0.3s var(--ease-out-cubic);

    &:hover {
      color: var(--color-brand-1);
    }
  }

  .blog-post__header {
    max-width: 42rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .blog-post__date {
    @extend %u-text;
    --fs: var(--font-size-xs);
    --fw: 400;
    color: var(--color-text-alt);
    display: block;
    margin-bottom: 1rem;
  }

  .blog-post__title {
    @extend %u-heading;
    --fs: 2.4rem;
    --fw: 300;
    --lh: 1.15;
    margin: 0 0 1rem;

    @media (--mq-tablet) {
      --fs: 1.8rem;
    }

    @media (--mq-phone) {
      --fs: 1.5rem;
    }
  }

  .blog-post__author {
    @extend %u-text;
    --fs: var(--font-size-sm);
    --fw: 350;
    color: var(--color-text-alt);
  }

  .blog-post__content {
    max-width: 42rem;
    margin: 0 auto;
  }
</style>

<style is:global>
  .prose {
    line-height: 1.7;
    color: var(--color-text);
  }

  .prose p {
    margin: 0 0 1.5em;
    font: 350 var(--font-size-md) / 1.7 var(--font-inter);
    letter-spacing: -0.01em;
  }

  .prose h2 {
    font: 300 1.4rem / 1.25 var(--font-roboto-slab);
    letter-spacing: -0.01em;
    margin: 2.5em 0 0.75em;
  }

  .prose h3 {
    font: 350 1.15rem / 1.3 var(--font-roboto-slab);
    letter-spacing: -0.01em;
    margin: 2em 0 0.5em;
  }

  .prose a {
    color: var(--color-brand-1);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    transition: opacity 0.3s var(--ease-out-cubic);
  }

  .prose a:hover {
    opacity: 0.7;
  }

  .prose code {
    font-size: 0.85em;
    background: var(--color-brand-3);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose pre {
    background: var(--color-brand-3);
    padding: 1.25em 1.5em;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
  }

  .prose ul,
  .prose ol {
    margin: 0 0 1.5em;
    padding-left: 1.5em;
  }

  .prose li {
    margin-bottom: 0.4em;
    font: 350 var(--font-size-md) / 1.6 var(--font-inter);
  }

  .prose blockquote {
    border-left: 2px solid rgba(var(--rgb-brand-1), 0.3);
    margin: 1.5em 0;
    padding: 0.5em 0 0.5em 1.5em;
    color: var(--color-text-alt);
  }

  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5em 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid rgba(var(--rgb-text), 0.06);
    margin: 2.5em 0;
  }
</style>
