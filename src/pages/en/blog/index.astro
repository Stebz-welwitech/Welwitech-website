---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Blog — Welwitech" description="Thoughts on design, tech and AI by the Welwitech team.">
  <section class="blog-index">
    <div class="blog-index__header">
      <h1 class="blog-index__title u-heading">Blog</h1>
      <p class="blog-index__subtitle u-text">Coming soon</p>
      <p class="blog-index__back u-text">
        <a href="/en/" class="blog-index__link">← Back to homepage</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .blog-index {
    @extend %u-container;
    padding-top: 10rem;
    padding-bottom: 6rem;
  }

  .blog-index__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .blog-index__title {
    @extend %u-heading;
    --fs: 3rem;
    --fw: 300;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 1rem;

    @media (--mq-tablet) {
      --fs: 2.2rem;
    }
  }

  .blog-index__subtitle {
    @extend %u-text;
    --fs: var(--font-size-md);
    --fw: 350;
    color: var(--color-text-alt);
    margin: 0 0 2rem;
  }

  .blog-index__back {
    margin: 0;
  }

  .blog-index__link {
    @extend %u-text;
    --fs: var(--font-size-sm);
    --fw: 400;
    text-decoration: none;
    color: var(--color-brand-1);
    transition: opacity 0.3s var(--ease-out-cubic);

    &:hover {
      opacity: 0.7;
    }
  }
</style>
