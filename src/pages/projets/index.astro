---

<Layout title="Nos réalisations — Welwitech" description="Découvrez les projets conçus et développés par Welwitech : SaaS, apps mobiles, plateformes, sites corporate et solutions IA.">
  <section class="projets">
    <div class="container">
      <header class="header">
        <h1 class="u-heading title">Nos réalisations</h1>
        <p class="u-text subtitle">{projets.length} projets livrés. Zéro abandonné.</p>
      </header>

      <div class="grid">
        {
          projets.map((p) => (
            <a href={p.url} class="card">
              <div class="card-image">
                <img src={p.image} alt={p.title} loading="lazy" decoding="async" />
              </div>
              <div class="card-content">
                <span class="card-type u-text">{p.type}</span>
                <h2 class="card-title u-heading">{p.title}</h2>
                <p class="card-desc u-text">{p.description}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .projets {
    padding: 10rem 0 6rem;
  }

  .container {
    @extend %u-container;
  }

  .header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .title {
    --fs: clamp(2rem, 4vw, 3rem);
    --fw: 300;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    --fs: var(--font-size-md);
    color: var(--color-text-alt);
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;

    @media (--mq-phone) {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(var(--rgb-text), 0.06);
    background: var(--color-white);
    transition: box-shadow 0.4s var(--ease-out-cubic), transform 0.4s var(--ease-out-cubic);

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(var(--rgb-text), 0.06);
    }
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-brand-3);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s var(--ease-out-cubic);
    }
  }

  .card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;

    @media (--mq-phone) {
      padding: 1.25rem;
    }
  }

  .card-type {
    --fs: var(--font-size-xs);
    --fw: 400;
    color: rgb(var(--rgb-brand-1));
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-title {
    --fs: 1.15rem;
    --fw: 400;
    color: var(--color-text);
    margin: 0;
  }

  .card-desc {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    margin: 0;
    line-height: 1.5;
  }
</style>
